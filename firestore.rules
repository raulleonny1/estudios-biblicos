rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Mantener alineado con config/admin-emails.json + NEXT_PUBLIC_ADMIN_EMAILS
    // Ejecutar: npm run sync:admin-emails
    function isConfiguredAdminEmail() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() in ['admin@admin.com'];
    }

    function isAdmin() {
      return isConfiguredAdminEmail()
        || (
          signedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && userDoc().data.role == 'admin'
        );
    }

    function roleChangeIsSafe() {
      let nextRole = request.resource.data.get('role', resource.data.get('role', 'student'));
      let prevRole = resource.data.get('role', 'student');
      return nextRole == prevRole
        || (nextRole == 'admin' && isConfiguredAdminEmail());
    }

    function sameAuthEmail() {
      return signedIn()
        && request.auth.token.email != null
        && resource.data.email == request.auth.token.email.lower();
    }

    function validPrayerRequestCreate() {
      let data = request.resource.data;
      return data.firstName is string
        && data.firstName.size() > 0
        && data.lastName is string
        && data.lastName.size() > 0
        && data.phone is string
        && data.phone.size() >= 7
        && data.reason is string
        && data.reason.size() > 0
        && data.createdAt is string;
    }

    function validAnalyticsCreate() {
      let data = request.resource.data;
      return data.event is string
        && data.event.size() > 0
        && data.createdAt is string;
    }

    function validLeaderboardWrite() {
      let data = request.resource.data;
      return data.uid == request.auth.uid
        && data.displayName is string
        && data.displayName.size() > 0
        && data.displayName.size() <= 120
        && data.points is number
        && data.points >= 0
        && data.updatedAt is string;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || sameAuthEmail();
      allow list: if isAdmin() || sameAuthEmail();
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.role in ['student', 'admin']
        && (request.resource.data.role == 'student' || isConfiguredAdminEmail());
      allow update: if isAdmin() || (isOwner(userId) && roleChangeIsSafe());
      allow delete: if isAdmin();
    }

    // Ranking público: solo nombre visible + puntos (sin email/teléfono).
    match /publicLeaderboard/{uid} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.uid == uid
        && (
          (isOwner(uid) && validLeaderboardWrite())
          || (isAdmin()
            && request.resource.data.displayName is string
            && request.resource.data.points is number
            && request.resource.data.points >= 0
            && request.resource.data.updatedAt is string)
        );
      allow delete: if isAdmin() || isOwner(uid);
    }

    match /lessonSubmissions/{submissionId} {
      allow read: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.uid == request.auth.uid
          && resource.data.status != 'approved'
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == 'pending'
        );
      allow delete: if isAdmin();
    }

    match /lessonProgress/{progressId} {
      allow read: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /lessonContent/{lessonId} {
      allow read: if signedIn()
        && (
          !resource.exists
          || resource.data.isPublished == true
          || isAdmin()
        );
      allow create, update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /announcementAttendance/{recordId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /prayerRequests/{requestId} {
      allow create: if validPrayerRequestCreate();
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    match /prayerRequestsArchive/{archiveId} {
      allow create: if isAdmin();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /analyticsEvents/{eventId} {
      allow create: if validAnalyticsCreate();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /weeklyBulletins/{bulletinId} {
      allow read: if signedIn()
        && (resource.data.isPublished == true || isAdmin());
      allow create, update, delete: if isAdmin();
    }
  }
}
